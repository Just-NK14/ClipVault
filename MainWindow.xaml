<Window x:Class="ClipVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoeticKit - ClipVault" Height="520" Width="700" 
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize" 
        Closing="Window_Closing">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="ClipVault" FontSize="24" FontWeight="Bold" Margin="0,0,0,2" HorizontalAlignment="Center"/>
            <TextBlock Text="10-Slot Clipboard Manager" FontSize="13" Foreground="Gray" HorizontalAlignment="Center"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Rows="5" Columns="2">

            <StackPanel Margin="10,5">
                <TextBlock Text="Slot 1 (Copy: Alt+1 | Paste: Ctrl+Alt+1)" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="Slot1TextBox" Height="40" TextWrapping="Wrap" AcceptsReturn="True" Background="#F9F9F9"/>
            </StackPanel>

            <StackPanel Margin="10,5">
                <TextBlock Text="Slot 2 (Copy: Alt+2 | Paste: Ctrl+Alt+2)" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="Slot2TextBox" Height="40" TextWrapping="Wrap" AcceptsReturn="True" Background="#F9F9F9"/>
            </StackPanel>

            <StackPanel Margin="10,5">
                <TextBlock Text="Slot 3 (Copy: Alt+3 | Paste: Ctrl+Alt+3)" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="Slot3TextBox" Height="40" TextWrapping="Wrap" AcceptsReturn="True" Background="#F9F9F9"/>
            </StackPanel>

            <StackPanel Margin="10,5">
                <TextBlock Text="Slot 4 (Copy: Alt+4 | Paste: Ctrl+Alt+4)" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="Slot4TextBox" Height="40" TextWrapping="Wrap" AcceptsReturn="True" Background="#F9F9F9"/>
            </StackPanel>

            <StackPanel Margin="10,5">
                <TextBlock Text="Slot 5 (Copy: Alt+5 | Paste: Ctrl+Alt+5)" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="Slot5TextBox" Height="40" TextWrapping="Wrap" AcceptsReturn="True" Background="#F9F9F9"/>
            </StackPanel>

            <StackPanel Margin="10,5">
                <TextBlock Text="Slot 6 (Copy: Alt+6 | Paste: Ctrl+Alt+6)" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="Slot6TextBox" Height="40" TextWrapping="Wrap" AcceptsReturn="True" Background="#F9F9F9"/>
            </StackPanel>

            <StackPanel Margin="10,5">
                <TextBlock Text="Slot 7 (Copy: Alt+7 | Paste: Ctrl+Alt+7)" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="Slot7TextBox" Height="40" TextWrapping="Wrap" AcceptsReturn="True" Background="#F9F9F9"/>
            </StackPanel>

            <StackPanel Margin="10,5">
                <TextBlock Text="Slot 8 (Copy: Alt+8 | Paste: Ctrl+Alt+8)" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="Slot8TextBox" Height="40" TextWrapping="Wrap" AcceptsReturn="True" Background="#F9F9F9"/>
            </StackPanel>

            <StackPanel Margin="10,5">
                <TextBlock Text="Slot 9 (Copy: Alt+9 | Paste: Ctrl+Alt+9)" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="Slot9TextBox" Height="40" TextWrapping="Wrap" AcceptsReturn="True" Background="#F9F9F9"/>
            </StackPanel>

            <StackPanel Margin="10,5">
                <TextBlock Text="Slot 0 (Copy: Alt+0 | Paste: Ctrl+Alt+0)" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="Slot0TextBox" Height="40" TextWrapping="Wrap" AcceptsReturn="True" Background="#F9F9F9"/>
            </StackPanel>

        </UniformGrid>
    </Grid>
</Window>